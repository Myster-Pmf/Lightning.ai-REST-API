# Lightning-API Configuration
SECRET_KEY=your-secret-key-change-this
DEBUG=False
PORT=5000

# Lightning AI Studio Configuration
STUDIO_NAME=your-studio-name
TEAMSPACE=your-teamspace
USERNAME=your-username

# Lightning AI API Credentials (Required for each user)
# Get these from Lightning AI dashboard: https://lightning.ai/
LIGHTNING_USER_ID=your-lightning-user-id
LIGHTNING_API_KEY=your-lightning-api-key

# Note: In production, each user should provide their own 
# LIGHTNING_USER_ID and LIGHTNING_API_KEY with API requests
# Do not share these credentials between users!